rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== MÜŞTERİLER =====
    // Okuma: açık (personel/admin QR okuma için lazım)
    // Oluşturma: sadece auth sahibi kendi kaydını oluşturur
    // Güncelleme: doğrulama ile (damga sınırları)
    // Silme: açık (admin silme için)
    match /customers/{custId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.auth.uid == custId
                    && request.resource.data.keys().hasAll(['name', 'phone', 'email', 'level'])
                    && request.resource.data.level == 'misafir'
                    && request.resource.data.currentCard == 0
                    && request.resource.data.totalStamps == 0;
      allow update: if request.resource.data.currentCard is int
                    && request.resource.data.totalStamps is int
                    && request.resource.data.currentCard >= 0
                    && request.resource.data.currentCard <= 7
                    && request.resource.data.totalStamps >= 0
                    && request.resource.data.level in ['misafir', 'mudavim', 'goat'];
      allow delete: if true;
    }

    // ===== DAMGA LOGLARI =====
    // Oluşturma: doğrulama ile — düzenleme/silme KESİNLİKLE YASAK
    match /stampLogs/{logId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['customerId', 'customerName', 'type', 'timestamp'])
                    && request.resource.data.type in ['stamp', 'free_redeemed', 'goat_monthly', 'admin_add', 'admin_remove', 'referral_bonus']
                    && request.resource.data.customerId is string
                    && request.resource.data.customerName is string;
      allow update, delete: if false;
    }

    // ===== PERSONEL =====
    match /staff/{staffId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name', 'username', 'pin', 'role', 'branch', 'status'])
                    && request.resource.data.status in ['active', 'inactive']
                    && request.resource.data.pin is string;
      allow update, delete: if true;
    }

    // ===== AYARLAR =====
    // Yeni ayar oluşturulamaz, silinemez — sadece güncelleme
    match /settings/{settingId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if false;
    }

    // ===== KAMPANYALAR =====
    // Silinemez, doğrulama ile oluşturulur
    match /campaigns/{campId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['title', 'active'])
                    && request.resource.data.title is string
                    && request.resource.data.title.size() > 0
                    && request.resource.data.title.size() < 200;
      allow update, delete: if true;
    }

    // ===== ŞUBELER =====
    // Silinemez
    match /branches/{branchId} {
      allow read: if true;
      allow create, update: if request.resource.data.name is string;
      allow delete: if false;
    }

    // ===== MENÜ =====
    match /menuItems/{itemId} {
      allow read: if true;
      allow create, update: if request.resource.data.name is string
                   && request.resource.data.category is string;
      allow delete: if true;
    }

    // ===== LOGIN GİRİŞİM TAKİBİ =====
    match /loginAttempts/{attemptId} {
      allow read, write: if true;
    }

    // Diğer her şeyi kapat
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
